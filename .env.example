# Django
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=sqlite:///db.sqlite3

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0

# Email (tu cuenta de Mail.app de Mac)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.mail.me.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True

# macOS Integrations
# Ruta local de Calendario de Mac (CalDAV local)
MACOS_CALENDAR_PATH=~/Library/Calendars
# Ruta local de Contactos de Mac
MACOS_CONTACTS_PATH=~/Library/Application Support/AddressBook
# Directorio de archivos del CRM (local)
CRM_FILES_DIR=~/Documents/TalentoSostenible/Archivos

# AI Settings
AI_SCORING_ENABLED=True
